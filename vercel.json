{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/coach-chat.js": {
      "includeFiles": "maenads_system_prompt.md",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/.netlify/functions/coach-chat",
      "destination": "/api/coach-chat"
    }
  ]
}
