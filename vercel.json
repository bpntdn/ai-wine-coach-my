{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "node scripts/copy-static-for-vercel.js",
  "outputDirectory": "dist",
  "functions": {
    "api/coach-chat.js": {
      "includeFiles": "maenads_system_prompt.md",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/.netlify/functions/coach-chat",
      "destination": "/api/coach-chat"
    }
  ]
}
